# Copy this file to .env and fill in your keys.
# .env is gitignored and must never be committed.

# Agent orchestration (tool calling) - https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Tool 1: video search - https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your_serpapi_key_here

# Tool 2: transcription - https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Optional model overrides (defaults shown)
# AGENT_MODEL=openai/gpt-oss-120b
# GEMINI_MODEL=gemini-flash-latest

# Optional: restrict which browser origin may call /api/transcribe.
# Leave unset for a same-origin deployment (the frontend calling its own API).
# Set to your deployed URL, or a comma-separated list, to allow specific
# cross-origin callers. "*" allows any origin (not recommended).
# ALLOWED_ORIGIN=https://your-app.vercel.app
